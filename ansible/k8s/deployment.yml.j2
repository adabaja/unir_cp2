# Deployment: 1 réplica de la app, imagen desde MI ACR (pull con AcrPull),
# con el PVC montado en /data — donde la app guarda valor e historial.
apiVersion: apps/v1
kind: Deployment
metadata:
  name: app-k8s
  namespace: default
spec:
  replicas: 1
  selector:
    matchLabels:
      app: app-k8s
  template:
    metadata:
      labels:
        app: app-k8s
    spec:
      # La app corre sin privilegios; fsGroup da permiso de escritura
      # sobre el volumen (Azure Disk se monta propiedad de root)
      securityContext:
        runAsUser: 1000
        runAsGroup: 1000
        fsGroup: 1000
      containers:
        - name: app-k8s
          image: "{{ acr_server }}/app-k8s:casopractico2"
          imagePullPolicy: Always
          ports:
            - containerPort: 8000
          volumeMounts:
            - name: datos
              mountPath: /data
      volumes:
        - name: datos
          persistentVolumeClaim:
            claimName: app-k8s-datos